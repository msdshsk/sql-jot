{
  "name": "sql-jot",
  "version": "0.1.0",
  "description": "Emmet-like shorthand syntax that expands into SQL",
  "author": "msd.shsk <msd.shsk@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msdshsk/sql-jot.git"
  },
  "homepage": "https://github.com/msdshsk/sql-jot#readme",
  "bugs": {
    "url": "https://github.com/msdshsk/sql-jot/issues"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "README.ja.md",
    "SYNTAX.md",
    "SYNTAX.ja.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build:grammar": "peggy --format es --dts -o src/parser.generated.js src/grammar.peggy",
    "build": "npm run build:grammar && tsc",
    "test": "npm run build:grammar && vitest run",
    "test:watch": "npm run build:grammar && vitest",
    "prepare": "npm run build:grammar",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sql",
    "emmet",
    "shorthand",
    "monaco",
    "dsl",
    "query-builder"
  ],
  "devDependencies": {
    "peggy": "^4.0.3",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "@types/node": "^20.12.7"
  }
}
